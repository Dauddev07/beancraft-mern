# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/beancraft

# Used to sign JWTs — use a long random string in production
JWT_SECRET=change_this_to_a_long_random_secret

# Use 5050 on Mac — port 5000 is often taken by AirPlay Receiver (breaks API with 403).
PORT=5050

# Dev: Vite URL. Production (split deploy): exact frontend origin, e.g. https://your-app.vercel.app
CLIENT_URL=http://localhost:5173

# Created on first seed if missing (use strong values in production)
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin123
